# Application Environment
NODE_ENV=production

# Server Configuration
PORT=3001

APP_BASE_URL=https://thaillm.or.th/medical-siriraj-api

# Frontend Configuration
FRONTEND_BASE_URL=https://thaillm.or.th/medical-siriraj
FRONTEND_EMAIL_VERIFICATION_CALLBACK_URL=https://thaillm.or.th//medical-siriraj/auth/verified-email
FRONTEND_EMAIL_VERIFICATION_FAILED_CALLBACK_URL=https://thaillm.or.th/medical-siriraj/auth/verify-email
FRONTEND_RESET_PASSWORD_CALLBACK_URL=https://thaillm.or.th/medical-siriraj/auth/reset-password

LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-5.4
LLM_ENABLE_TOOLS=true

MEDICAL_FACTS_API_URL=http://dev-vectordb.chatbot.svc.cluster.local

PRESCREEN_API_URL=http://prod-prescreen-rulesets.chatbot.svc.cluster.local/api/v1

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_MAIL_FROM=no-reply@thaillm.or.th
SMTP_FROM_NAME=ThaiLLM
SMTP_USE_TLS=false

DB_AUTO_MIGRATION=true

ENABLE_CRON_JOB=true

ADMIN_EMAILS=

EMAIL_TEMPLATE_QUEUE=bdi.email.template.queue

VAPID_KEYS_PUBLIC_KEY=changeme